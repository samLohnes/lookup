# Copy to `.env` and fill in your values. Pydantic-settings reads .env at startup.
# All settings are prefixed with SATVIS_ in the environment.

# ---------------------------------------------------------------------------
# OpenTopography API key — REQUIRED for /passes and /horizon to work.
# Register free at https://portal.opentopography.org/
# ---------------------------------------------------------------------------
SATVIS_OPENTOPOGRAPHY_API_KEY=

# ---------------------------------------------------------------------------
# Optional overrides — uncomment to change from defaults.
# ---------------------------------------------------------------------------

# Where cached TLEs, DEM tiles, and horizon masks are stored.
# Default: ~/.satvis
# SATVIS_CACHE_ROOT=/absolute/path/to/cache

# How stale TLEs can be before /passes auto-refreshes from Celestrak.
# Default: 24
# SATVIS_TLE_MAX_AGE_HOURS=24

# Radius (km) around the observer that the DEM tile covers.
# Default: 50
# SATVIS_HORIZON_RADIUS_KM=50

# Host + port the launcher binds to. 127.0.0.1 keeps the API local-only.
# Defaults: 127.0.0.1 and 8765
# SATVIS_HOST=127.0.0.1
# SATVIS_PORT=8765
